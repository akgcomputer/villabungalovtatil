---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';

// Slider verileri
const slider1 = {
  id: 'slider1',
  image: '/images/tatil-adam-1.png',
  bgImages: ['/images/konum1.png', '/images/konum2.png'],
  title: 'Şehirden uzak ama yakın yerde 3 gün ne kadar güzel olurdu..',
  buttons: ['En Popüler Ev', 'En Popüler Tatil Yeri']
};

const slider2 = {
  id: 'slider2',
  image: '/images/tatil-kadin-1.png',
  bgImages: ['/images/konum2.png', '/images/konum3-explorer.png'],
  title: 'Neden yakın yerler..',
  titleIcon: '/images/soru-isareti.png', // Özel ikon resmi
  features: [
    {
      icon: '/images/saat-ikonu.png',
      title: 'Zamanımız Yok',
      desc: 'İstanbul ve tüm büyük şehirlerin kalabalığı ve stresinden kurtulmak için zaman kaybetmeden bazen 2-3 gün bazen de 4-5 günlüğüne kafamızı dinlemek isteriz ama uzağa gitmeye zaman YOK, araçla ya da toplu taşıma ile yakın yerlere gitmek daha mantıklı bir seçim oluyor.'
    },
    {
      icon: '/images/ekonomi-ikonu.png',
      title: 'Çok ekonomik',
      desc: 'Yakın yerlere gitmek başta zaman sonra da maliyet anlamında çok da yormuyor. Uzak yerlere gitmek araç-yakıt-uçak git gel masraf vs derken ekonomik olmuyor.'
    },
    {
      icon: '/images/doga-ikonu.png',
      title: 'Bozulmamış Doğa',
      desc: 'Başta İstanbul\'a yakın yerlerde ve diğer büyükşehirlere yakın yerlerde halen doğası ile büyüleyen bir çok lokasyon bulunmakta, neden uzak yerlere gidesiniz ki!!'
    }
  ],
  buttons: ['En Popüler Lokasyon', 'En Merak Edilen Tatil Yeri']
};

// Tur kartları verileri - resimli
const tourSliders = [
  {
    title: 'Keşfetmeye Hazır Mısın?',
    titleImage: '/images/kesfet-ikon.png',
    cards: [
      { name: 'Balkan Turları', image: '/images/balkan-tur.jpg', slogan: 'Tarih ve kültür dolu bir yolculuk', locations: 'Bulgaristan, Yunanistan, Makedonya, Sırbistan' },
      { name: 'Umre Turları', image: '/images/umre-tur.jpg', slogan: 'Manevi bir yolculuk', locations: 'Mekke, Medine, Taif' },
      { name: 'Avrupa Turları', image: '/images/avrupa-tur.jpg', slogan: 'Rüya gibi şehirler', locations: 'Fransa, İtalya, İsviçre, İspanya' },
      { name: 'Uzakdoğu Turları', image: '/images/uzakdogu-tur.jpg', slogan: 'Egzotik bir macera', locations: 'Tayland, Vietnam, Japonya, Güney Kore' }
    ]
  },
  {
    title: 'Farklı Deneyimler Seni Bekliyor',
    titleImage: '/images/deneyim-ikon.png',
    cards: [
      { name: 'Afrika Turları', image: '/images/afrika-tur.jpg', slogan: 'Vahşi yaşam ve doğa', locations: 'Güney Afrika, Kenya, Tanzanya, Fas' },
      { name: 'Körfez Turları', image: '/images/korfez-tur.jpg', slogan: 'Lüks ve modernlik', locations: 'BAE, Katar, Kuveyt, Umman' },
      { name: 'Cruiz - Gemi Turları', image: '/images/gemi-tur.jpg', slogan: 'Denizde keyifli günler', locations: 'Akdeniz, Karayipler, Norveç Fiyordları' },
      { name: 'Ticari Turlar', image: '/images/ticari-tur.jpg', slogan: 'İş ve fırsat bir arada', locations: 'Çin, Hindistan, Almanya, ABD' }
    ]
  }
];

// Şehir logoları listesi (10 tane, bilecik çıkarıldı)
const sehirLogolari = [
  { name: 'istanbul', label: 'İstanbul', page: 'istanbul.astro' },
  { name: 'bursa', label: 'Bursa', page: 'bursa.astro' },
  { name: 'balikesir', label: 'Balıkesir', page: 'balikesir.astro' },
  { name: 'yalova', label: 'Yalova', page: 'yalova.astro' },
  { name: 'sakarya', label: 'Sakarya', page: 'sakarya.astro' },
  { name: 'kocaeli', label: 'Kocaeli', page: 'kocaeli.astro' },
  { name: 'tekirdag', label: 'Tekirdağ', page: 'tekirdag.astro' },
  { name: 'canakkale', label: 'Çanakkale', page: 'canakkale.astro' },
  { name: 'kirklareli', label: 'Kırklareli', page: 'kirklareli.astro' },
  { name: 'edirne', label: 'Edirne', page: 'edirne.astro' }
];

// Popüler Evler
const populerEvler = [
  { id: 1, img: '/images/populer-tatil-1.png', link: '#' },
  { id: 2, img: '/images/populer-tatil-2.png', link: '#' },
  { id: 3, img: '/images/populer-tatil-3.png', link: '#' },
  { id: 4, img: '/images/populer-tatil-4.png', link: '#' }
];
---

<Layout title="Villa Bungalov Tatil - Şehrin Stresinden Uzak, Doğayla İç İçe Tatil">
  <!-- Header'dan sonra direkt 1. slider ile başlıyoruz (arama bölümü kaldırıldı) -->

  <!-- SLIDER 1: ADAM RESİMLİ (GERÇEK SLIDER) -->
  <div class="slider-container relative" data-slider="slider1">
    <div class="slider-track flex transition-transform duration-500 ease-out" style="transform: translateX(0%);">
      <!-- Slider 1 tek slayttan oluşuyor ama slider yapısını koruyoruz -->
      <div class="slider-slide w-full flex-shrink-0">
        <section class="relative overflow-hidden bg-gradient-to-br from-[#1e1a3a] to-[#2a235a] text-white min-h-[600px] flex items-center">
          <!-- Arkaplan resimleri (alttan gelen efekt) -->
          <div class="absolute inset-0 opacity-30">
            <img src="/images/konum1.png" alt="" class="absolute bottom-0 left-0 w-64 md:w-96 animate-float-slow" loading="lazy">
            <img src="/images/konum2.png" alt="" class="absolute top-0 right-0 w-64 md:w-96 animate-float" loading="lazy">
          </div>
          
          <div class="relative max-w-7xl mx-auto px-4 py-12 md:py-16 w-full">
            <div class="grid md:grid-cols-2 gap-8 items-center">
              <!-- Sol: Resim (alttan hafif yükselme efekti) -->
              <div class="flex justify-center order-2 md:order-1 animate-slideUp">
                <div class="relative">
                  <img src="/images/tatil-adam-1.png" alt="Tatil konsepti" class="relative z-10 max-w-md w-full h-auto drop-shadow-2xl hover:scale-105 transition-transform duration-500" loading="lazy">
                </div>
              </div>
              <!-- Sağ: İçerik -->
              <div class="order-1 md:order-2 animate-fadeIn">
                <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-6 leading-tight">
                  <span class="inline-block bg-orange-500/20 p-2 rounded-full mr-3">🌴</span>
                  {slider1.title}
                </h2>
                <div class="flex flex-wrap gap-4">
                  {slider1.buttons.map((btn) => (
                    <a href="#" class="px-6 py-3 bg-orange-500 hover:bg-orange-600 text-white font-semibold rounded-full transition-all shadow-lg hover:shadow-xl text-sm md:text-base">
                      {btn}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </section>
      </div>
    </div>
    
    <!-- Slider okları (anlaşılır butonlar) -->
    <button class="slider-prev absolute left-2 md:left-4 top-1/2 -translate-y-1/2 w-10 h-10 md:w-12 md:h-12 bg-white/80 hover:bg-white rounded-full shadow-lg flex items-center justify-center text-gray-800 hover:text-orange-600 transition z-20 text-2xl font-bold">
      ←
    </button>
    <button class="slider-next absolute right-2 md:right-4 top-1/2 -translate-y-1/2 w-10 h-10 md:w-12 md:h-12 bg-white/80 hover:bg-white rounded-full shadow-lg flex items-center justify-center text-gray-800 hover:text-orange-600 transition z-20 text-2xl font-bold">
      →
    </button>
    
    <!-- Slider indicator -->
    <div class="slider-dots absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2 z-20">
      <button class="w-2 h-2 md:w-3 md:h-3 rounded-full bg-white/50 hover:bg-white transition slider-dot active" data-slide="0"></button>
      <button class="w-2 h-2 md:w-3 md:h-3 rounded-full bg-white/50 hover:bg-white transition slider-dot" data-slide="1"></button>
    </div>
  </div>

  <!-- SLIDER 2: KADIN RESİMLİ (GERÇEK SLIDER) -->
  <div class="slider-container relative" data-slider="slider2">
    <div class="slider-track flex transition-transform duration-500 ease-out" style="transform: translateX(0%);">
      <!-- Slider 2 tek slayttan oluşuyor -->
      <div class="slider-slide w-full flex-shrink-0">
        <section class="relative overflow-hidden bg-gradient-to-br from-[#162b3a] to-[#1d3a4a] text-white min-h-[600px] flex items-center">
          <!-- Arkaplan resimleri (alttan gelen efekt) -->
          <div class="absolute inset-0 opacity-30">
            <img src="/images/konum2.png" alt="" class="absolute top-0 left-0 w-64 md:w-96 rotate-12 animate-float-slow" loading="lazy">
            <img src="/images/konum3-explorer.png" alt="" class="absolute bottom-0 right-0 w-64 md:w-96 animate-float" loading="lazy">
          </div>
          
          <div class="relative max-w-7xl mx-auto px-4 py-12 md:py-16 w-full">
            <div class="grid md:grid-cols-2 gap-8 items-center">
              <!-- Sol: Resim (alttan hafif yükselme efekti) -->
              <div class="flex justify-center animate-slideUp">
                <img src="/images/tatil-kadin-1.png" alt="Tatil konsepti kadın" class="max-w-md w-full h-auto drop-shadow-2xl hover:scale-105 transition-transform duration-500" loading="lazy">
              </div>
              <!-- Sağ: İçerik -->
              <div class="animate-fadeIn">
                <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-6 flex items-center gap-3">
                  <img src={slider2.titleIcon} alt="?" class="w-10 h-10 md:w-12 md:h-12 object-contain" />
                  {slider2.title}
                </h2>
                
                <div class="space-y-6 mb-8">
                  {slider2.features.map((feature) => (
                    <div class="flex gap-4 items-start">
                      <img src={feature.icon} alt="" class="w-8 h-8 md:w-10 md:h-10 object-contain flex-shrink-0" />
                      <div>
                        <h3 class="text-xl font-semibold mb-1">{feature.title}</h3>
                        <p class="text-gray-200 text-sm leading-relaxed">{feature.desc}</p>
                      </div>
                    </div>
                  ))}
                </div>
                
                <div class="flex flex-wrap gap-4">
                  {slider2.buttons.map((btn) => (
                    <a href="#" class="px-6 py-3 bg-teal-500 hover:bg-teal-600 text-white font-semibold rounded-full transition-all shadow-lg hover:shadow-xl text-sm md:text-base">
                      {btn}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </section>
      </div>
    </div>
    
    <!-- Slider okları aynı container içinde -->
    <button class="slider-prev absolute left-2 md:left-4 top-1/2 -translate-y-1/2 w-10 h-10 md:w-12 md:h-12 bg-white/80 hover:bg-white rounded-full shadow-lg flex items-center justify-center text-gray-800 hover:text-orange-600 transition z-20 text-2xl font-bold">
      ←
    </button>
    <button class="slider-next absolute right-2 md:right-4 top-1/2 -translate-y-1/2 w-10 h-10 md:w-12 md:h-12 bg-white/80 hover:bg-white rounded-full shadow-lg flex items-center justify-center text-gray-800 hover:text-orange-600 transition z-20 text-2xl font-bold">
      →
    </button>
    
    <!-- Slider indicator -->
    <div class="slider-dots absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2 z-20">
      <button class="w-2 h-2 md:w-3 md:h-3 rounded-full bg-white/50 hover:bg-white transition slider-dot active" data-slide="0"></button>
      <button class="w-2 h-2 md:w-3 md:h-3 rounded-full bg-white/50 hover:bg-white transition slider-dot" data-slide="1"></button>
    </div>
  </div>

  <!-- SLIDER 3: TURLAR - RESİMLİ KARTLAR -->
  <section class="bg-gray-50 py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex items-center gap-3 mb-8">
        <img src={tourSliders[0].titleImage} alt="" class="w-10 h-10 md:w-12 md:h-12 object-contain" />
        <h2 class="text-2xl md:text-3xl font-bold text-gray-800">{tourSliders[0].title}</h2>
      </div>
      
      <!-- Gerçek slider yapısı -->
      <div class="slider-container-tour relative">
        <div class="tour-track flex gap-4 overflow-x-auto snap-x snap-mandatory scrollbar-hide pb-4" style="scrollbar-width: none; -ms-overflow-style: none;">
          {tourSliders[0].cards.map((card) => (
            <div class="flex-shrink-0 w-72 snap-start">
              <div class="bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-xl transition border border-gray-100 h-full group">
                <div class="h-40 overflow-hidden">
                  <img src={card.image} alt={card.name} class="w-full h-full object-cover group-hover:scale-110 transition duration-500" loading="lazy">
                </div>
                <div class="p-5">
                  <h3 class="text-xl font-bold text-gray-800 mb-2">{card.name}</h3>
                  <p class="text-gray-600 text-sm mb-3">{card.slogan}</p>
                  <p class="text-xs text-gray-500 mb-4">📍 {card.locations}</p>
                  <a href="#" class="block w-full text-center px-4 py-2 bg-orange-500 hover:bg-orange-600 text-white font-medium rounded-lg text-sm transition">
                    İncele
                  </a>
                </div>
              </div>
            </div>
          ))}
        </div>
        
        <!-- Ok butonları (masaüstünde görünür) -->
        <button class="tour-prev absolute left-0 top-1/2 -translate-y-1/2 -translate-x-4 w-10 h-10 bg-white rounded-full shadow-lg flex items-center justify-center text-gray-600 hover:bg-gray-100 hover:text-orange-600 transition z-10 hidden md:flex">
          ←
        </button>
        <button class="tour-next absolute right-0 top-1/2 -translate-y-1/2 translate-x-4 w-10 h-10 bg-white rounded-full shadow-lg flex items-center justify-center text-gray-600 hover:bg-gray-100 hover:text-orange-600 transition z-10 hidden md:flex">
          →
        </button>
      </div>
    </div>
  </section>

  <!-- SLIDER 4: TURLAR - 2. SLIDER -->
  <section class="bg-white py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex items-center gap-3 mb-8">
        <img src={tourSliders[1].titleImage} alt="" class="w-10 h-10 md:w-12 md:h-12 object-contain" />
        <h2 class="text-2xl md:text-3xl font-bold text-gray-800">{tourSliders[1].title}</h2>
      </div>
      
      <div class="slider-container-tour2 relative">
        <div class="tour2-track flex gap-4 overflow-x-auto snap-x snap-mandatory scrollbar-hide pb-4" style="scrollbar-width: none; -ms-overflow-style: none;">
          {tourSliders[1].cards.map((card) => (
            <div class="flex-shrink-0 w-72 snap-start">
              <div class="bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-xl transition border border-gray-100 h-full group">
                <div class="h-40 overflow-hidden">
                  <img src={card.image} alt={card.name} class="w-full h-full object-cover group-hover:scale-110 transition duration-500" loading="lazy">
                </div>
                <div class="p-5">
                  <h3 class="text-xl font-bold text-gray-800 mb-2">{card.name}</h3>
                  <p class="text-gray-600 text-sm mb-3">{card.slogan}</p>
                  <p class="text-xs text-gray-500 mb-4">📍 {card.locations}</p>
                  <a href="#" class="block w-full text-center px-4 py-2 bg-orange-500 hover:bg-orange-600 text-white font-medium rounded-lg text-sm transition">
                    İncele
                  </a>
                </div>
              </div>
            </div>
          ))}
        </div>
        
        <button class="tour2-prev absolute left-0 top-1/2 -translate-y-1/2 -translate-x-4 w-10 h-10 bg-white rounded-full shadow-lg flex items-center justify-center text-gray-600 hover:bg-gray-100 hover:text-orange-600 transition z-10 hidden md:flex">
          ←
        </button>
        <button class="tour2-next absolute right-0 top-1/2 -translate-y-1/2 translate-x-4 w-10 h-10 bg-white rounded-full shadow-lg flex items-center justify-center text-gray-600 hover:bg-gray-100 hover:text-orange-600 transition z-10 hidden md:flex">
          →
        </button>
      </div>
    </div>
  </section>

  <!-- İSTANBUL İÇİ VE YAKIN YERLER (ŞEHİR LOGOLARI) -->
  <section class="py-12 md:py-16 bg-transparent">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-bold text-center text-gray-800 mb-10">
        İstanbul İçi ve Yakın Yerler
      </h2>
      
      <!-- Sabit duran logo grid -->
      <div class="flex flex-wrap justify-center gap-6 md:gap-8">
        {sehirLogolari.map((sehir) => (
          <a href={`/${sehir.page}`} class="group relative flex flex-col items-center">
            <div class="relative w-20 h-20 md:w-24 md:h-24">
              <!-- Ana logo -->
              <img 
                src={`/images/logo-${sehir.name}-150x150.png`} 
                alt={sehir.label}
                class="w-full h-full rounded-full object-cover border-4 border-white shadow-lg relative z-10"
                loading="lazy"
                onerror="this.onerror=null; this.src='/images/logo-${sehir.name}.png'"
              />
              <!-- LED efekti - dönen border (düzeltildi) -->
              <div class="absolute inset-0 rounded-full rotating-border"></div>
            </div>
            <span class="block text-center mt-2 text-sm font-medium text-gray-700 group-hover:text-orange-600 transition">
              {sehir.label}
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- POPÜLER EVLER -->
  <section class="bg-white py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-bold text-gray-800 mb-8 text-center md:text-left">
        Popüler Evler
      </h2>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {populerEvler.map((ev) => (
          <a href={ev.link} class="group block">
            <div class="bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-2xl transition-all hover:-translate-y-2">
              <div class="relative h-[530px] overflow-hidden">
                <img 
                  src={ev.img} 
                  alt={`Popüler tatil evi ${ev.id}`}
                  class="w-full h-full object-cover group-hover:scale-105 transition duration-500"
                  loading="lazy"
                />
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- DEVAM EDECEK... -->
  <section class="bg-gray-50 py-8 text-center text-gray-500">
    <p>Diğer sectionlar yakında eklenecek...</p>
  </section>
</Layout>

<style is:global>
  /* Scrollbar'ı gizle */
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  
  /* LED efekti - düzeltilmiş versiyon (tamamen kaplıyor) */
  .rotating-border {
    position: absolute;
    top: -3px;
    left: -3px;
    right: -3px;
    bottom: -3px;
    border-radius: 50%;
    background: conic-gradient(from 0deg, #ff6b6b, #feca57, #ff9ff3, #54a0ff, #5f27cd, #ff6b6b);
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask-composite: exclude;
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    padding: 3px;
    animation: rotate 3s linear infinite;
    z-index: 5;
    pointer-events: none;
  }
  
  @keyframes rotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  
  /* Animasyonlar */
  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-20px); }
  }
  
  @keyframes float-slow {
    0%, 100% { transform: translateY(0px) rotate(12deg); }
    50% { transform: translateY(-15px) rotate(12deg); }
  }
  
  @keyframes slideUp {
    from { transform: translateY(50px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }
  
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }
  
  .animate-float-slow {
    animation: float-slow 8s ease-in-out infinite;
  }
  
  .animate-slideUp {
    animation: slideUp 0.8s ease-out;
  }
  
  .animate-fadeIn {
    animation: fadeIn 1s ease-out;
  }
  
  /* Slider container'ların beyaz zemin olmaması için */
  .slider-container {
    background: transparent;
  }
  
  /* Slider okları hover efekti */
  .slider-prev:hover, .slider-next:hover {
    transform: translateY(-50%) scale(1.1);
  }
  
  /* Aktif slider dot */
  .slider-dot.active {
    background-color: #f97316;
    transform: scale(1.2);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Ana slider'lar için slider işlevselliği
    const setupMainSlider = (container) => {
      const track = container.querySelector('.slider-track');
      const slides = container.querySelectorAll('.slider-slide');
      const prevBtn = container.querySelector('.slider-prev');
      const nextBtn = container.querySelector('.slider-next');
      const dots = container.querySelectorAll('.slider-dot');
      
      if (!track || slides.length === 0) return;
      
      let currentIndex = 0;
      const slideCount = slides.length;
      
      const updateSlider = (index) => {
        if (index < 0) index = slideCount - 1;
        if (index >= slideCount) index = 0;
        
        track.style.transform = `translateX(-${index * 100}%)`;
        currentIndex = index;
        
        // Dot'ları güncelle
        dots.forEach((dot, i) => {
          if (i === index) dot.classList.add('active');
          else dot.classList.remove('active');
        });
      };
      
      if (prevBtn) {
        prevBtn.addEventListener('click', () => {
          updateSlider(currentIndex - 1);
        });
      }
      
      if (nextBtn) {
        nextBtn.addEventListener('click', () => {
          updateSlider(currentIndex + 1);
        });
      }
      
      dots.forEach((dot, index) => {
        dot.addEventListener('click', () => {
          updateSlider(index);
        });
      });
      
      // Otomatik slider (opsiyonel)
      // setInterval(() => {
      //   updateSlider(currentIndex + 1);
      // }, 5000);
    };
    
    // Tüm ana slider'ları kur
    document.querySelectorAll('.slider-container[data-slider]').forEach(setupMainSlider);
    
    // Tour slider'ları için kaydırma butonları
    const setupTourSlider = (containerClass, trackClass, prevClass, nextClass) => {
      const container = document.querySelector(containerClass);
      if (!container) return;
      
      const track = container.querySelector(trackClass);
      const prevBtn = container.querySelector(prevClass);
      const nextBtn = container.querySelector(nextClass);
      
      if (!track || !prevBtn || !nextBtn) return;
      
      const scrollAmount = 300; // Bir kart genişliği + gap
      
      prevBtn.addEventListener('click', () => {
        track.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
      });
      
      nextBtn.addEventListener('click', () => {
        track.scrollBy({ left: scrollAmount, behavior: 'smooth' });
      });
    };
    
    setupTourSlider('.slider-container-tour', '.tour-track', '.tour-prev', '.tour-next');
    setupTourSlider('.slider-container-tour2', '.tour2-track', '.tour2-prev', '.tour2-next');
  });
</script>