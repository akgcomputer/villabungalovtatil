                />
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- KEŞFETMEYE HAZIR MISIN? - 4 Kart -->
  <section class="py-16 md:py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex items-center justify-center md:justify-start gap-3 mb-10">
