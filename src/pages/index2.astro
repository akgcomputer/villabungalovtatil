</Layout>

<style is:global>
  /* Özel fontlar */
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Caveat:wght@400;700&display=swap');
  
  .font-slogan {
    font-family: 'Playfair Display', serif;
    font-weight: 700;
  }
  
  .font-hand {
    font-family: 'Caveat', cursive;
  }
  
  /* LED efekti - düzeltilmiş versiyon */
  .rotating-border {
    position: absolute;
    top: -3px;
    left: -3px;
    right: -3px;
    bottom: -3px;
    border-radius: 50%;
    background: conic-gradient(from 0deg, #ff6b6b, #feca57, #ff9ff3, #54a0ff, #5f27cd, #ff6b6b);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask-composite: exclude;
    padding: 3px;
    animation: rotate 3s linear infinite;
    z-index: 5;
    pointer-events: none;
  }
  
  @keyframes rotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  
  /* Animasyonlar */
  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-20px); }
  }
  
  @keyframes float-slow {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-15px); }
  }
  
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }
  
  .animate-float-slow {
    animation: float-slow 8s ease-in-out infinite;
  }
  
  /* Slider okları hover efekti */
  .slider-prev:hover, .slider-next:hover {
    transform: translateY(-50%) scale(1.1);
    background-color: white;
  }
  
  /* Aktif slider dot */
  .slider-dot.active {
    background-color: #f97316;
    transform: scale(1.2);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Ana slider
    const slider = document.getElementById('anaSlider');
    if (!slider) return;
    
    const track = slider.querySelector('.slider-track');
    const slides = slider.querySelectorAll('.slider-slide');
    const prevBtn = slider.querySelector('.slider-prev');
    const nextBtn = slider.querySelector('.slider-next');
    const dots = slider.querySelectorAll('.slider-dot');
    
    if (!track || slides.length === 0) return;
    
    let currentIndex = 0;
    const slideCount = slides.length;
    let autoSlideInterval;
    
    const updateSlider = (index) => {
      if (index < 0) index = slideCount - 1;
      if (index >= slideCount) index = 0;
      
      track.style.transform = `translateX(-${index * 100}%)`;
      currentIndex = index;
      
      // Dot'ları güncelle
      dots.forEach((dot, i) => {
        if (i === index) dot.classList.add('active');
        else dot.classList.remove('active');
      });
    };
    
    // Ok butonları
    if (prevBtn) {
      prevBtn.addEventListener('click', () => {
        updateSlider(currentIndex - 1);
        resetAutoSlide();
      });
    }
    
    if (nextBtn) {
      nextBtn.addEventListener('click', () => {
        updateSlider(currentIndex + 1);
        resetAutoSlide();
      });
    }
    
    // Dot'lar
    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        updateSlider(index);
        resetAutoSlide();
      });
    });
    
    // Otomatik geçiş - 8 saniyede bir (hız düşürüldü)
    const startAutoSlide = () => {
      autoSlideInterval = setInterval(() => {
        updateSlider(currentIndex + 1);
      }, 8000); // 8 saniye
    };
    
    const resetAutoSlide = () => {
      clearInterval(autoSlideInterval);
      startAutoSlide();
    };
    
    // Başlat
    startAutoSlide();
    
    // Slider üzerine gelince otomatik geçişi durdur
    slider.addEventListener('mouseenter', () => {
      clearInterval(autoSlideInterval);
    });
    
    slider.addEventListener('mouseleave', () => {
      startAutoSlide();
    });
  });
</script>