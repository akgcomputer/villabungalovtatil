              <!-- Ana logo -->
              <img 
                src={`/images/logo-${sehir.name === 'İstanbul' ? 'istanbul' : sehir.name.toLowerCase()}-150x150.png`} 
                alt={sehir.label}
                class="w-full h-full rounded-full object-cover border-4 border-white shadow-lg relative z-10"
                loading="lazy"
                onerror="this.onerror=null; this.src='/images/logo-istanbul.png'"
              />
              <!-- LED efekti -->
              <div class="absolute inset-0 rounded-full rotating-border"></div>
            </div>
            <span class="block text-center mt-3 text-sm font-medium text-gray-700 group-hover:text-orange-600 transition">
              {sehir.label}
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- POPÜLER YERLER -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-bold text-gray-800 mb-10 text-center md:text-left">
        Popüler Yerler
      </h2>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {populerYerler.map((yer) => (
          <a href={yer.link} class="group block">
            <div class="bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-2xl transition-all hover:-translate-y-2">
              <div class="relative aspect-[4/3] overflow-hidden">
                <img 
                  src={yer.img} 
