---
import Layout from '../layouts/Layout.astro';
import { villalar } from '../data/villalar';

// Rastgele villa seçme fonksiyonu
function rastgeleVilla() {
  if (villalar.length === 0) return '#';
  const randomIndex = Math.floor(Math.random() * villalar.length);
  return `/villa/${villalar[randomIndex].slug}`;
}

// Rastgele şehir seçme fonksiyonu
function rastgeleSehir() {
  const sehirler = ['istanbul', 'bursa', 'sakarya', 'kocaeli', 'yalova', 'tekirdag', 'canakkale', 'kirklareli', 'edirne', 'balikesir'];
  const randomIndex = Math.floor(Math.random() * sehirler.length);
  return `/sehir/${sehirler[randomIndex]}`;
}

// Şehir adını slug'a çeviren fonksiyon (Türkçe karakterler için)
function sehirToSlug(sehirAdi) {
  if (!sehirAdi) return '';
  if (sehirAdi === 'İstanbul') return 'istanbul';
  return sehirAdi.toLowerCase()
    .replace(/ı/g, 'i')
    .replace(/ğ/g, 'g')
    .replace(/ü/g, 'u')
    .replace(/ş/g, 's')
    .replace(/ö/g, 'o')
    .replace(/ç/g, 'c')
    .replace(/ /g, '-');
}

// Slider verileri (tek slider'da 2 slayt)
const sliderSlides = [
  {
    id: 'slide1',
    image: '/images/tatil-adam-1.png',
    bgImages: ['/images/konum1.png', '/images/konum2.png'],
    title: 'Şehirden uzak ama yakın yerde 3 gün ne kadar güzel olurdu..',
    buttons: [
      { text: 'En Popüler Ev', link: rastgeleVilla() },
      { text: 'En Popüler Tatil Yeri', link: rastgeleSehir() }
    ],
    buttonColors: 'bg-orange-500 hover:bg-orange-600'
  },
  {
    id: 'slide2',
    image: '/images/tatil-kadin-1.png',
    bgImages: ['/images/konum2.png', '/images/konum3-explorer.png'],
    title: 'Neden yakın yerler..',
    titleIcon: '/images/soru-isareti.png',
    features: [
      {
        icon: '/images/saat-ikonu.png',
        title: 'Zamanımız Yok',
        desc: 'İstanbul ve tüm büyük şehirlerin kalabalığı ve stresinden kurtulmak için zaman kaybetmeden bazen 2-3 gün bazen de 4-5 günlüğüne kafamızı dinlemek isteriz ama uzağa gitmeye zaman YOK, araçla ya da toplu taşıma ile yakın yerlere gitmek daha mantıklı bir seçim oluyor.'
      },
      {
        icon: '/images/ekonomi-ikonu.png',
        title: 'Çok ekonomik',
        desc: 'Yakın yerlere gitmek başta zaman sonra da maliyet anlamında çok da yormuyor. Uzak yerlere gitmek araç-yakıt-uçak git gel masraf vs derken ekonomik olmuyor.'
      },
      {
        icon: '/images/doga-ikonu.png',
        title: 'Bozulmamış Doğa',
        desc: 'Başta İstanbul\'a yakın yerlerde ve diğer büyükşehirlere yakın yerlerde halen doğası ile büyüleyen bir çok lokasyon bulunmakta, neden uzak yerlere gidesiniz ki!!'
      }
    ],
    buttons: [
      { text: 'En Popüler Lokasyon', link: rastgeleSehir() },
      { text: 'En Merak Edilen Tatil Yeri', link: rastgeleSehir() }
    ],
    buttonColors: 'bg-teal-500 hover:bg-teal-600'
  }
];

// Tur kartları verileri
const turKartlari1 = [
  { name: 'Balkan Turları', image: '/images/balkan.jpg', link: '/tur/balkan' },
  { name: 'Umre Turları', image: '/images/umre.jpg', link: '/tur/umre' },
  { name: 'Avrupa Turları', image: '/images/avrupa.jpg', link: '/tur/avrupa' },
  { name: 'Uzakdoğu Turları', image: '/images/uzakdogu.jpg', link: '/tur/uzakdogu' }
];

const turKartlari2 = [
  { name: 'Körfez Turları', image: '/images/korfez.jpg', link: '/tur/korfez' },
  { name: 'Afrika Turları', image: '/images/afrika.jpg', link: '/tur/afrika' },
  { name: 'Gemi Turları', image: '/images/gemi.jpg', link: '/tur/gemi' },
  { name: 'Ticari Turlar', image: '/images/ticari.jpg', link: '/tur/ticari' }
];

// Şehir logoları listesi (9 tane)
const sehirLogolari = [
  { name: 'İstanbul', label: 'İstanbul', page: '/sehir/istanbul' },
  { name: 'Bursa', label: 'Bursa', page: '/sehir/bursa' },
  { name: 'Balıkesir', label: 'Balıkesir', page: '/sehir/balikesir' },
  { name: 'Yalova', label: 'Yalova', page: '/sehir/yalova' },
  { name: 'Sakarya', label: 'Sakarya', page: '/sehir/sakarya' },
  { name: 'Kocaeli', label: 'Kocaeli', page: '/sehir/kocaeli' },
  { name: 'Tekirdağ', label: 'Tekirdağ', page: '/sehir/tekirdag' },
  { name: 'Çanakkale', label: 'Çanakkale', page: '/sehir/canakkale' },
  { name: 'Kırklareli', label: 'Kırklareli', page: '/sehir/kirklareli' }
];

// Popüler Yerler (resim linkleri)
const populerYerler = [
  { id: 1, img: '/images/populer-tatil-1.png', link: '/sehir/yalova' },
  { id: 2, img: '/images/populer-tatil-2.png', link: '/sehir/sakarya' },
  { id: 3, img: '/images/populer-tatil-3.png', link: '/sehir/kocaeli' },
  { id: 4, img: '/images/populer-tatil-4.png', link: '/sehir/istanbul' }
];
---

<Layout title="Villa Bungalov Tatil - Şehrin Stresinden Uzak, Doğayla İç İçe Tatil">
  <!-- SLOGAN - En üstte, güzel bir font ile -->
  <div class="bg-white py-6 border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <h1 class="font-slogan text-3xl md:text-4xl lg:text-5xl text-gray-800 leading-relaxed">
        Şehrin Stresinden Uzak, 
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-500 to-purple-600">Doğayla İç İçe Tatil İçin..</span>
      </h1>
      <p class="font-hand text-xl text-gray-500 mt-2">VillaBungalovTatil.com.tr</p>
    </div>
  </div>

  <!-- TEK SLIDER - 2 slaytlı, otomatik geçişli (8 saniye) -->
  <div class="slider-main relative overflow-hidden" id="anaSlider">
    <div class="slider-track flex transition-transform duration-700 ease-out" style="transform: translateX(0%);">
      {sliderSlides.map((slide, index) => (
        <div class="slider-slide w-full flex-shrink-0">
          <section class={`relative overflow-hidden text-white min-h-[600px] flex items-center ${index === 0 ? 'bg-gradient-to-br from-[#1e1a3a] to-[#2a235a]' : 'bg-gradient-to-br from-[#162b3a] to-[#1d3a4a]'}`}>
            <!-- Arkaplan resimleri -->
            <div class="absolute inset-0 opacity-30">
              {slide.bgImages.map((bgImg, i) => (
                <img 
                  key={i}
                  src={bgImg} 
                  alt="" 
                  class={`absolute ${i === 0 ? 'bottom-0 left-0 animate-float-slow' : 'top-0 right-0 animate-float'}`}
                  style={{ width: '16rem' }}
                  loading="lazy"
                />
              ))}
            </div>
            
            <div class="relative max-w-7xl mx-auto px-4 py-12 md:py-16 w-full">
              <div class="grid md:grid-cols-2 gap-8 items-center">
                <!-- Sol: Resim -->
                <div class={`flex justify-center ${index === 0 ? 'order-2 md:order-1' : ''}`}>
                  <img 
                    src={slide.image} 
                    alt="Tatil konsepti" 
                    class="max-w-md w-full h-auto drop-shadow-2xl hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                  />
                </div>
                <!-- Sağ: İçerik -->
                <div class={index === 0 ? 'order-1 md:order-2' : ''}>
                  {index === 0 ? (
                    <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-6 leading-tight">
                      <span class="inline-block bg-orange-500/20 p-2 rounded-full mr-3">🌴</span>
                      {slide.title}
                    </h2>
                  ) : (
                    <>
                      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-6 flex items-center gap-3">
                        <img src={slide.titleIcon} alt="?" class="w-10 h-10 md:w-12 md:h-12 object-contain" />
                        {slide.title}
                      </h2>
                      
                      <div class="space-y-6 mb-8">
                        {slide.features.map((feature) => (
                          <div class="flex gap-4 items-start">
                            <img src={feature.icon} alt="" class="w-8 h-8 md:w-10 md:h-10 object-contain flex-shrink-0" />
                            <div>
                              <h3 class="text-xl font-semibold mb-1">{feature.title}</h3>
                              <p class="text-gray-200 text-sm leading-relaxed">{feature.desc}</p>
                            </div>
                          </div>
                        ))}
                      </div>
                    </>
                  )}
                  
                  <div class="flex flex-wrap gap-4">
                    {slide.buttons.map((btn, i) => (
                      <a 
                        href={btn.link} 
                        class={`px-6 py-3 ${slide.buttonColors} text-white font-semibold rounded-full transition-all shadow-lg hover:shadow-xl text-sm md:text-base`}
                        key={i}
                      >
                        {btn.text}
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </section>
        </div>
      ))}
    </div>
    
    <!-- Ok butonları -->
    <button class="slider-prev absolute left-2 md:left-4 top-1/2 -translate-y-1/2 w-10 h-10 md:w-12 md:h-12 bg-white/80 hover:bg-white rounded-full shadow-lg flex items-center justify-center text-gray-800 hover:text-orange-600 transition z-20 text-2xl font-bold">
      ←
    </button>
    <button class="slider-next absolute right-2 md:right-4 top-1/2 -translate-y-1/2 w-10 h-10 md:w-12 md:h-12 bg-white/80 hover:bg-white rounded-full shadow-lg flex items-center justify-center text-gray-800 hover:text-orange-600 transition z-20 text-2xl font-bold">
      →
    </button>
    
    <!-- Indicator noktaları -->
    <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2 z-20">
      <button class="slider-dot w-2 h-2 md:w-3 md:h-3 rounded-full bg-white/50 hover:bg-white transition active" data-slide="0"></button>
      <button class="slider-dot w-2 h-2 md:w-3 md:h-3 rounded-full bg-white/50 hover:bg-white transition" data-slide="1"></button>
    </div>
  </div>

  <!-- SLIDER3 ÖRNEĞİ - İLERİDE KULLANMAK İÇİN (şimdilik pasif) -->
