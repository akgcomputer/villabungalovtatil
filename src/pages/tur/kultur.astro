---

<Layout title="Kültür Turları - Tarih ve Sanat Dolu Rotalar | Villa Bungalov Tatil">
  <div class="container py-4 py-md-5">
    <TurTemplate
      title="Kültür Turları"
      description="Tarihin derinliklerine yolculuk, sanatın başkentlerinde keşif ve unutulmaz kültürel deneyimler."
      icon="📚"
      kategori="Kültür"
      fiyatlar={turFiyatlari.kultur}
      paraBirimi="EUR"
      paketler={paketler}
    />
  </div>
</Layout>