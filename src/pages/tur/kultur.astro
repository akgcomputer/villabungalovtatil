    vurgulu: true,
    ozellikler: [
      { etiket: 'Konaklama', deger: 'Tarihi Oteller' },
      { etiket: 'Ulaşım', deger: 'THY ile' },
      { etiket: 'Öne Çıkanlar', deger: 'Müzeler, Antik Kentler' },
      { etiket: 'Rehber', deger: 'Sanat Tarihçisi' }
    ]
  },
  {
    id: 'ispanya',
    baslik: 'İspanya Kültür Turu',
    altBaslik: 'Endülüs Mirası',
    gun: '8 Gece 9 Gün',
    ikon: '🎭',
    ozellikler: [
      { etiket: 'Konaklama', deger: 'Butik Oteller' },
      { etiket: 'Ulaşım', deger: 'THY ile' },
      { etiket: 'Öne Çıkanlar', deger: 'El Hamra, Flamenco' },
      { etiket: 'Rehber', deger: 'Yerel Rehber' }
    ]
  },
  {
    id: 'yunanistan',
    baslik: 'Yunanistan Kültür Turu',
    altBaslik: 'Antik Yunan İzinde',
    gun: '6 Gece 7 Gün',
    ikon: '🏺',
    ozellikler: [
      { etiket: 'Konaklama', deger: 'Merkezi Oteller' },
      { etiket: 'Ulaşım', deger: 'Pegasus' },
