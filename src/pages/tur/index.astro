---
// src/pages/tur/index.astro
import Layout from '../../layouts/Layout.astro';
import ContactButtons from '../../components/ContactButtons.astro';

const turKategorileri = [
  { name: 'Balkan Turları', href: '/tur/balkan', icon: '🏔️', desc: 'Tarih, kültür ve doğa iç içe' },
  { name: 'Avrupa Turları', href: '/tur/avrupa', icon: '🇪🇺', desc: 'Sanat, tarih ve romantizm' },
  { name: 'Uzak Doğu Turları', href: '/tur/uzakdogu', icon: '🎋', desc: 'Egzotik kültürler ve modern şehirler' },
  { name: 'Afrika Turları', href: '/tur/afrika', icon: '🦁', desc: 'Safari, çöl ve binlerce yıllık tarih' },
  { name: 'Körfez Turları', href: '/tur/korfez', icon: '🏜️', desc: 'Modern mimari ve çöl macerası' },
  { name: 'Gemi Turları', href: '/tur/gemi', icon: '🚢', desc: 'Akdeniz, Karayipler, Norveç fiyordları' },
  { name: 'Kültür Turları', href: '/tur/kultur', icon: '📚', desc: 'Tarih ve sanat dolu rotalar' },
  { name: 'Umre Turları', href: '/tur/umre', icon: '🕋', desc: 'Manevi yolculuk' }
];
---

<Layout title="Turlar - Villa Bungalov Tatil">
  <div class="container py-5">
    <div class="text-center mb-5">
      <h1 class="display-5 fw-bold text-primary">Tur Kategorileri</h1>
      <p class="lead text-muted">Hayalinizdeki rotayı seçin, unutulmaz bir yolculuğa çıkın</p>
    </div>

    <div class="row g-4">
      {turKategorileri.map(kategori => (
        <div class="col-md-6 col-lg-3">
          <a href={kategori.href} class="text-decoration-none">
            <div class="card h-100 border-0 shadow-sm hover-scale">
              <div class="card-body text-center p-4">
                <div class="display-1 mb-3">{kategori.icon}</div>
                <h3 class="h5 fw-bold text-primary mb-2">{kategori.name}</h3>
                <p class="small text-muted">{kategori.desc}</p>
                <div class="mt-3">
                  <span class="btn btn-outline-primary btn-sm">İncele →</span>
                </div>
              </div>
            </div>
          </a>
        </div>
      ))}
    </div>

    <style>
      .hover-scale {
        transition: transform 0.2s ease-in-out;
      }
      .hover-scale:hover {
        transform: translateY(-5px);
      }
    </style>
  </div>
</Layout>