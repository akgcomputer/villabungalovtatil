---
// src/pages/hakkimizda.astro
import Layout from '../layouts/Layout.astro';
import PageTemplate from '../components/PageTemplate.astro';
import ContactButtons from '../components/ContactButtons.astro';
---

<Layout title="Hakkımızda - Villa Bungalov Tatil">
  <PageTemplate 
    title="Hakkımızda" 
    subtitle="Hayalinizdeki tatili bulmanız için buradayız"
    lastUpdated="Mart 2026"
  >
    <div class="space-y-8">
      <!-- Vizyon -->
      <div>
        <h2 class="text-xl font-semibold text-gray-800 mb-3 flex items-center gap-2">
          <span class="text-orange-500">🏝️</span> Vizyonumuz
        </h2>
        <p class="text-gray-600 leading-relaxed">
          Villa Bungalov Tatil olarak, Türkiye'nin en güzel bölgelerinde doğayla iç içe, 
          huzurlu ve unutulmaz tatil deneyimleri sunmayı hedefliyoruz. Misafirlerimize 
          şehrin stresinden uzak, konforlu ve özel anlar yaşatacak mekanları bir araya getiriyoruz.
        </p>
      </div>

      <!-- Misyon -->
      <div>
        <h2 class="text-xl font-semibold text-gray-800 mb-3 flex items-center gap-2">
          <span class="text-orange-500">🎯</span> Misyonumuz
        </h2>
        <p class="text-gray-600 leading-relaxed">
          Villa sahipleri ile tatilcileri doğrudan buluşturarak, komisyonsuz ve güvenli bir 
          platform oluşturmak. Her bütçeye ve zevke uygun seçenekler sunarak, herkesin 
          hayalindeki tatile kavuşmasını sağlamak.
        </p>
      </div>

      <!-- Neden Biz? -->
      <div>
        <h2 class="text-xl font-semibold text-gray-800 mb-3 flex items-center gap-2">
          <span class="text-orange-500">✨</span> Neden Villa Bungalov Tatil?
        </h2>
        <ul class="space-y-3 text-gray-600">
          <li class="flex items-start gap-3">
            <span class="text-green-500 mt-1">✓</span>
            <span><span class="font-medium">Geniş Seçenek:</span> Türkiye'nin dört bir yanında yüzlerce villa ve bungalov</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-green-500 mt-1">✓</span>
            <span><span class="font-medium">Doğrudan İletişim:</span> Villa sahipleriyle birebir iletişim, aracısız rezervasyon</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-green-500 mt-1">✓</span>
            <span><span class="font-medium">Güvenli Ödeme:</span> Kaparo koruması ile güvenli rezervasyon</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-green-500 mt-1">✓</span>
            <span><span class="font-medium">7/24 Destek:</span> Tatiliniz boyunca her an yanınızda</span>
          </li>
        </ul>
      </div>

      <!-- İletişim Butonları -->
      <div class="border-t border-gray-100 pt-6 mt-6">
        <p class="text-gray-600 mb-4">Sorularınız mı var? Hemen ulaşın!</p>
        <ContactButtons message="Hakkınızda bilgi almak istiyorum" />
      </div>
    </div>
  </PageTemplate>
</Layout>