---
// src/pages/iletisim.astro
import Layout from '../layouts/Layout.astro';
import PageTemplate from '../components/PageTemplate.astro';
import ContactButtons, { iletisim } from '../components/ContactButtons.astro';
---

<Layout title="İletişim - Villa Bungalov Tatil">
  <PageTemplate 
    title="İletişim" 
    subtitle="Size yardımcı olmaktan mutluluk duyarız"
  >
    <div class="grid md:grid-cols-2 gap-8">
      <!-- Sol Kolon: İletişim Bilgileri -->
      <div class="space-y-6">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 bg-orange-100 rounded-full flex items-center justify-center flex-shrink-0">
            <span class="text-orange-600 text-xl">📞</span>
          </div>
          <div>
            <h3 class="font-semibold text-gray-800">Telefon</h3>
            <a href={`tel:${iletisim.phone}`} class="text-orange-600 hover:underline text-lg">
              {iletisim.phone}
            </a>
            <p class="text-sm text-gray-500">Hafta içi 09:00 - 18:00</p>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <div class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center flex-shrink-0">
            <span class="text-green-600 text-xl">📱</span>
          </div>
          <div>
            <h3 class="font-semibold text-gray-800">WhatsApp</h3>
            <a href={`https://wa.me/${iletisim.whatsapp}`} target="_blank" class="text-green-600 hover:underline text-lg">
              {iletisim.whatsapp}
            </a>
            <p class="text-sm text-gray-500">7/24 anında destek</p>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center flex-shrink-0">
            <span class="text-blue-600 text-xl">✉️</span>
          </div>
          <div>
            <h3 class="font-semibold text-gray-800">E-posta</h3>
            <a href={`mailto:${iletisim.email}`} class="text-blue-600 hover:underline">
              {iletisim.email}
            </a>
            <p class="text-sm text-gray-500">En geç 24 saat içinde dönüş</p>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <div class="w-10 h-10 bg-purple-100 rounded-full flex items-center justify-center flex-shrink-0">
            <span class="text-purple-600 text-xl">📍</span>
          </div>
          <div>
            <h3 class="font-semibold text-gray-800">Adres</h3>
            <p class="text-gray-600">İstanbul, Türkiye</p>
            <p class="text-sm text-gray-500">Merkez ofisimiz İstanbul'da</p>
          </div>
        </div>

        <!-- Sosyal Medya -->
        <div class="pt-4">
          <h3 class="font-semibold text-gray-800 mb-3">Bizi Takip Edin</h3>
          <div class="flex gap-3">
            <a href="#" class="w-10 h-10 bg-gray-800 hover:bg-orange-600 rounded-full flex items-center justify-center text-white transition-colors">
              <span>📘</span>
            </a>
            <a href="#" class="w-10 h-10 bg-gray-800 hover:bg-orange-600 rounded-full flex items-center justify-center text-white transition-colors">
              <span>📷</span>
            </a>
            <a href="#" class="w-10 h-10 bg-gray-800 hover:bg-orange-600 rounded-full flex items-center justify-center text-white transition-colors">
              <span>🐦</span>
            </a>
            <a href="#" class="w-10 h-10 bg-gray-800 hover:bg-orange-600 rounded-full flex items-center justify-center text-white transition-colors">
              <span>🎵</span>
            </a>
          </div>
        </div>
      </div>

      <!-- Sağ Kolon: İletişim Formu -->
      <div class="bg-gray-50 rounded-xl p-6">
        <h3 class="text-lg font-semibold text-gray-800 mb-4">Bize Mesaj Gönderin</h3>
        <form class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Adınız Soyadınız</label>
            <input type="text" class="w-full border border-gray-300 rounded-lg p-3 focus:ring-2 focus:ring-orange-500 focus:border-transparent" placeholder="Adınız Soyadınız" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">E-posta Adresiniz</label>
            <input type="email" class="w-full border border-gray-300 rounded-lg p-3 focus:ring-2 focus:ring-orange-500 focus:border-transparent" placeholder="ornek@email.com" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Telefon</label>
            <input type="tel" class="w-full border border-gray-300 rounded-lg p-3 focus:ring-2 focus:ring-orange-500 focus:border-transparent" placeholder="05XX XXX XX XX" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Mesajınız</label>
            <textarea rows="4" class="w-full border border-gray-300 rounded-lg p-3 focus:ring-2 focus:ring-orange-500 focus:border-transparent" placeholder="Mesajınızı yazın..."></textarea>
          </div>
          <button type="submit" class="w-full bg-orange-600 hover:bg-orange-700 text-white font-medium py-3 rounded-lg transition-colors">
            Gönder
          </button>
        </form>
        <p class="text-xs text-gray-400 mt-3 text-center">
          * Form doldurarak KVKK metnini kabul etmiş olursunuz.
        </p>
      </div>
    </div>
  </PageTemplate>
</Layout>