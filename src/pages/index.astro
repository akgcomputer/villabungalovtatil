---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';

// Slider verileri (tek slider'da 2 slayt)
const sliderSlides = [
  {
    id: 'slide1',
    image: '/images/tatil-adam-1.png',
    bgImages: ['/images/konum1.png', '/images/konum2.png'],
    title: 'Şehirden uzak ama yakın yerde 3 gün ne kadar güzel olurdu..',
    buttons: ['En Popüler Ev', 'En Popüler Tatil Yeri'],
    buttonColors: 'bg-orange-500 hover:bg-orange-600'
  },
  {
    id: 'slide2',
    image: '/images/tatil-kadin-1.png',
    bgImages: ['/images/konum2.png', '/images/konum3-explorer.png'],
    title: 'Neden yakın yerler..',
    titleIcon: '/images/soru-isareti.png',
    features: [
      {
        icon: '/images/saat-ikonu.png',
        title: 'Zamanımız Yok',
        desc: 'İstanbul ve tüm büyük şehirlerin kalabalığı ve stresinden kurtulmak için zaman kaybetmeden bazen 2-3 gün bazen de 4-5 günlüğüne kafamızı dinlemek isteriz ama uzağa gitmeye zaman YOK, araçla ya da toplu taşıma ile yakın yerlere gitmek daha mantıklı bir seçim oluyor.'
      },
      {
        icon: '/images/ekonomi-ikonu.png',
        title: 'Çok ekonomik',
        desc: 'Yakın yerlere gitmek başta zaman sonra da maliyet anlamında çok da yormuyor. Uzak yerlere gitmek araç-yakıt-uçak git gel masraf vs derken ekonomik olmuyor.'
      },
      {
        icon: '/images/doga-ikonu.png',
        title: 'Bozulmamış Doğa',
        desc: 'Başta İstanbul\'a yakın yerlerde ve diğer büyükşehirlere yakın yerlerde halen doğası ile büyüleyen bir çok lokasyon bulunmakta, neden uzak yerlere gidesiniz ki!!'
      }
    ],
    buttons: ['En Popüler Lokasyon', 'En Merak Edilen Tatil Yeri'],
    buttonColors: 'bg-teal-500 hover:bg-teal-600'
  }
];

// Tur kartları verileri (4 kart - slider yok)
const turKartlari1 = [
  { name: 'Balkan Turları', image: '/images/balkan-tur.jpg', slogan: 'Tarih ve kültür dolu bir yolculuk', locations: 'Bulgaristan, Yunanistan, Makedonya, Sırbistan' },
  { name: 'Umre Turları', image: '/images/umre-tur.jpg', slogan: 'Manevi bir yolculuk', locations: 'Mekke, Medine, Taif' },
  { name: 'Avrupa Turları', image: '/images/avrupa-tur.jpg', slogan: 'Rüya gibi şehirler', locations: 'Fransa, İtalya, İsviçre, İspanya' },
  { name: 'Uzakdoğu Turları', image: '/images/uzakdogu-tur.jpg', slogan: 'Egzotik bir macera', locations: 'Tayland, Vietnam, Japonya, Güney Kore' }
];

const turKartlari2 = [
  { name: 'Afrika Turları', image: '/images/afrika-tur.jpg', slogan: 'Vahşi yaşam ve doğa', locations: 'Güney Afrika, Kenya, Tanzanya, Fas' },
  { name: 'Körfez Turları', image: '/images/korfez-tur.jpg', slogan: 'Lüks ve modernlik', locations: 'BAE, Katar, Kuveyt, Umman' },
  { name: 'Cruiz - Gemi Turları', image: '/images/gemi-tur.jpg', slogan: 'Denizde keyifli günler', locations: 'Akdeniz, Karayipler, Norveç Fiyordları' },
  { name: 'Ticari Turlar', image: '/images/ticari-tur.jpg', slogan: 'İş ve fırsat bir arada', locations: 'Çin, Hindistan, Almanya, ABD' }
];

// Şehir logoları listesi (10 tane, DOĞRU LİNK FORMATI)
const sehirLogolari = [
  { name: 'istanbul', label: 'İstanbul', page: '/istanbul' },
  { name: 'bursa', label: 'Bursa', page: '/bursa' },
  { name: 'balikesir', label: 'Balıkesir', page: '/balikesir' },
  { name: 'yalova', label: 'Yalova', page: '/yalova' },
  { name: 'sakarya', label: 'Sakarya', page: '/sakarya' },
  { name: 'kocaeli', label: 'Kocaeli', page: '/kocaeli' },
  { name: 'tekirdag', label: 'Tekirdağ', page: '/tekirdag' },
  { name: 'canakkale', label: 'Çanakkale', page: '/canakkale' },
  { name: 'kirklareli', label: 'Kırklareli', page: '/kirklareli' }
];

// Popüler Evler
const populerEvler = [
  { id: 1, img: '/images/populer-tatil-1.png', link: '#' },
  { id: 2, img: '/images/populer-tatil-2.png', link: '#' },
  { id: 3, img: '/images/populer-tatil-3.png', link: '#' },
  { id: 4, img: '/images/populer-tatil-4.png', link: '#' }
];
---

<Layout title="Villa Bungalov Tatil - Şehrin Stresinden Uzak, Doğayla İç İçe Tatil">
  <!-- SLOGAN - En üstte, güzel bir font ile -->
  <div class="bg-white py-6 border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <h1 class="font-hand font-slogan text-3xl md:text-4xl lg:text-5xl text-gray-800 leading-relaxed">
        Şehrin Stresinden Uzak, 
        <span class="font-hand text-transparent bg-clip-text bg-gradient-to-r from-orange-500 to-purple-600">Doğayla İç İçe Tatil İçin..</span>
      </h1>
      <p class="font-hand text-xl text-gray-500 mt-2">VillaBungalovTatil.com.tr</p>
    </div>
  </div>

  <!-- TEK SLIDER - 2 slaytlı, otomatik geçişli -->
  <div class="slider-main relative overflow-hidden" id="anaSlider">
    <div class="slider-track flex transition-transform duration-700 ease-out" style="transform: translateX(0%);">
      {sliderSlides.map((slide, index) => (
        <div class="slider-slide w-full flex-shrink-0">
          <section class={`relative overflow-hidden text-white min-h-[600px] flex items-center ${index === 0 ? 'bg-gradient-to-br from-[#1e1a3a] to-[#2a235a]' : 'bg-gradient-to-br from-[#162b3a] to-[#1d3a4a]'}`}>
            <!-- Arkaplan resimleri -->
            <div class="absolute inset-0 opacity-30">
              {slide.bgImages.map((bgImg, i) => (
                <img 
                  key={i}
                  src={bgImg} 
                  alt="" 
                  class={`absolute ${i === 0 ? 'bottom-0 left-0 animate-float-slow' : 'top-0 right-0 animate-float'}`}
                  style={{ width: '16rem' }}
                  loading="lazy"
                />
              ))}
            </div>
            
            <div class="relative max-w-7xl mx-auto px-4 py-12 md:py-16 w-full">
              <div class="grid md:grid-cols-2 gap-8 items-center">
                <!-- Sol: Resim -->
                <div class={`flex justify-center ${index === 0 ? 'order-2 md:order-1' : ''}`}>
                  <img 
                    src={slide.image} 
                    alt="Tatil konsepti" 
                    class="max-w-md w-full h-auto drop-shadow-2xl hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                  />
                </div>
                <!-- Sağ: İçerik -->
                <div class={index === 0 ? 'order-1 md:order-2' : ''}>
                  {index === 0 ? (
                    <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-6 leading-tight">
                      <span class="inline-block bg-orange-500/20 p-2 rounded-full mr-3">🌴</span>
                      {slide.title}
                    </h2>
                  ) : (
                    <>
                      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-6 flex items-center gap-3">
                        <img src={slide.titleIcon} alt="?" class="w-10 h-10 md:w-12 md:h-12 object-contain" />
                        {slide.title}
                      </h2>
                      
                      <div class="space-y-6 mb-8">
                        {slide.features.map((feature) => (
                          <div class="flex gap-4 items-start">
                            <img src={feature.icon} alt="" class="w-8 h-8 md:w-10 md:h-10 object-contain flex-shrink-0" />
                            <div>
                              <h3 class="text-xl font-semibold mb-1">{feature.title}</h3>
                              <p class="text-gray-200 text-sm leading-relaxed">{feature.desc}</p>
                            </div>
                          </div>
                        ))}
                      </div>
                    </>
                  )}
                  
                  <div class="flex flex-wrap gap-4">
                    {slide.buttons.map((btn, i) => (
                      <a 
                        href="#" 
                        class={`px-6 py-3 ${slide.buttonColors} text-white font-semibold rounded-full transition-all shadow-lg hover:shadow-xl text-sm md:text-base`}
                        key={i}
                      >
                        {btn}
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </section>
        </div>
      ))}
    </div>
    
    <!-- Ok butonları -->
    <button class="slider-prev absolute left-2 md:left-4 top-1/2 -translate-y-1/2 w-10 h-10 md:w-12 md:h-12 bg-white/80 hover:bg-white rounded-full shadow-lg flex items-center justify-center text-gray-800 hover:text-orange-600 transition z-20 text-2xl font-bold">
      ←
    </button>
    <button class="slider-next absolute right-2 md:right-4 top-1/2 -translate-y-1/2 w-10 h-10 md:w-12 md:h-12 bg-white/80 hover:bg-white rounded-full shadow-lg flex items-center justify-center text-gray-800 hover:text-orange-600 transition z-20 text-2xl font-bold">
      →
    </button>
    
    <!-- Indicator noktaları -->
    <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2 z-20">
      <button class="slider-dot w-2 h-2 md:w-3 md:h-3 rounded-full bg-white/50 hover:bg-white transition active" data-slide="0"></button>
      <button class="slider-dot w-2 h-2 md:w-3 md:h-3 rounded-full bg-white/50 hover:bg-white transition" data-slide="1"></button>
    </div>
  </div>

  <!-- İSTANBUL İÇİ VE YAKIN YERLER (ŞEHİR LOGOLARI) -->
  <section class="py-16 md:py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-bold text-center text-gray-800 mb-12">
        İstanbul İçi ve Yakın Tatil Yerleri
      </h2>
      
      <!-- Sabit duran logo grid -->
      <div class="flex flex-wrap justify-center gap-8 md:gap-10">
        {sehirLogolari.map((sehir) => (
          <a href={sehir.page} class="group relative flex flex-col items-center">
            <div class="relative w-20 h-20 md:w-24 md:h-24">
              <!-- Ana logo -->
              <img 
                src={`/images/logo-${sehir.name}-150x150.png`} 
                alt={sehir.label}
                class="w-full h-full rounded-full object-cover border-4 border-white shadow-lg relative z-10"
                loading="lazy"
                onerror="this.onerror=null; this.src='/images/logo-${sehir.name}.png'"
              />
              <!-- LED efekti - düzeltildi -->
              <div class="absolute inset-0 rounded-full rotating-border"></div>
            </div>
            <span class="block text-center mt-3 text-sm font-medium text-gray-700 group-hover:text-orange-600 transition">
              {sehir.label}
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- POPÜLER EVLER -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-bold text-gray-800 mb-10 text-center md:text-left">
        Popüler Evler
      </h2>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {populerEvler.map((ev) => (
          <a href={ev.link} class="group block">
            <div class="bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-2xl transition-all hover:-translate-y-2">
              <div class="relative h-[530px] overflow-hidden">
                <img 
                  src={ev.img} 
                  alt={`Popüler tatil evi ${ev.id}`}
                  class="w-full h-full object-cover group-hover:scale-105 transition duration-500"
                  loading="lazy"
                />
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- KEŞFETMEYE HAZIR MISIN? - 4 Kart (Slider yok) -->
  <section class="py-16 md:py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex items-center justify-center md:justify-start gap-3 mb-10">
        <img src="/images/kesfet-ikon.png" alt="" class="w-10 h-10 md:w-12 md:h-12 object-contain" />
        <h2 class="text-2xl md:text-3xl font-bold text-gray-800">Keşfetmeye Hazır Mısın?</h2>
      </div>
      
      <!-- 4 kart grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {turKartlari1.map((card) => (
          <div class="bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-xl transition border border-gray-100 h-full group">
            <div class="h-40 overflow-hidden">
              <img src={card.image} alt={card.name} class="w-full h-full object-cover group-hover:scale-110 transition duration-500" loading="lazy" />
            </div>
            <div class="p-5">
              <h3 class="text-xl font-bold text-gray-800 mb-2">{card.name}</h3>
              <p class="text-gray-600 text-sm mb-3">{card.slogan}</p>
              <p class="text-xs text-gray-500 mb-4 line-clamp-2">📍 {card.locations}</p>
              <a href="#" class="block w-full text-center px-4 py-2 bg-orange-500 hover:bg-orange-600 text-white font-medium rounded-lg text-sm transition">
                İncele
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FARKLI DENEYİMLER SENİ BEKLİYOR - 4 Kart -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex items-center justify-center md:justify-start gap-3 mb-10">
        <img src="/images/deneyim-ikon.png" alt="" class="w-10 h-10 md:w-12 md:h-12 object-contain" />
        <h2 class="text-2xl md:text-3xl font-bold text-gray-800">Farklı Deneyimler Seni Bekliyor</h2>
      </div>
      
      <!-- 4 kart grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {turKartlari2.map((card) => (
          <div class="bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-xl transition border border-gray-100 h-full group">
            <div class="h-40 overflow-hidden">
              <img src={card.image} alt={card.name} class="w-full h-full object-cover group-hover:scale-110 transition duration-500" loading="lazy" />
            </div>
            <div class="p-5">
              <h3 class="text-xl font-bold text-gray-800 mb-2">{card.name}</h3>
              <p class="text-gray-600 text-sm mb-3">{card.slogan}</p>
              <p class="text-xs text-gray-500 mb-4 line-clamp-2">📍 {card.locations}</p>
              <a href="#" class="block w-full text-center px-4 py-2 bg-orange-500 hover:bg-orange-600 text-white font-medium rounded-lg text-sm transition">
                İncele
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style is:global>
  /* Özel fontlar */
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Caveat:wght@400;700&display=swap');
  
  .font-slogan {
    font-family: 'Playfair Display', serif;
    font-weight: 700;
  }
  
  .font-hand {
    font-family: 'Caveat', cursive;
  }
  
  /* LED efekti - düzeltilmiş versiyon */
  .rotating-border {
    position: absolute;
    top: -3px;
    left: -3px;
    right: -3px;
    bottom: -3px;
    border-radius: 50%;
    background: conic-gradient(from 0deg, #ff6b6b, #feca57, #ff9ff3, #54a0ff, #5f27cd, #ff6b6b);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask-composite: exclude;
    padding: 3px;
    animation: rotate 3s linear infinite;
    z-index: 5;
    pointer-events: none;
  }
  
  @keyframes rotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  
  /* Animasyonlar */
  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-20px); }
  }
  
  @keyframes float-slow {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-15px); }
  }
  
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }
  
  .animate-float-slow {
    animation: float-slow 8s ease-in-out infinite;
  }
  
  /* Slider okları hover efekti */
  .slider-prev:hover, .slider-next:hover {
    transform: translateY(-50%) scale(1.1);
    background-color: white;
  }
  
  /* Aktif slider dot */
  .slider-dot.active {
    background-color: #f97316;
    transform: scale(1.2);
  }
  
  /* Line clamp için */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Ana slider
    const slider = document.getElementById('anaSlider');
    if (!slider) return;
    
    const track = slider.querySelector('.slider-track');
    const slides = slider.querySelectorAll('.slider-slide');
    const prevBtn = slider.querySelector('.slider-prev');
    const nextBtn = slider.querySelector('.slider-next');
    const dots = slider.querySelectorAll('.slider-dot');
    
    if (!track || slides.length === 0) return;
    
    let currentIndex = 0;
    const slideCount = slides.length;
    let autoSlideInterval;
    
    const updateSlider = (index) => {
      if (index < 0) index = slideCount - 1;
      if (index >= slideCount) index = 0;
      
      track.style.transform = `translateX(-${index * 100}%)`;
      currentIndex = index;
      
      // Dot'ları güncelle
      dots.forEach((dot, i) => {
        if (i === index) dot.classList.add('active');
        else dot.classList.remove('active');
      });
    };
    
    // Ok butonları
    if (prevBtn) {
      prevBtn.addEventListener('click', () => {
        updateSlider(currentIndex - 1);
        resetAutoSlide();
      });
    }
    
    if (nextBtn) {
      nextBtn.addEventListener('click', () => {
        updateSlider(currentIndex + 1);
        resetAutoSlide();
      });
    }
    
    // Dot'lar
    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        updateSlider(index);
        resetAutoSlide();
      });
    });
    
    // Otomatik geçiş
    const startAutoSlide = () => {
      autoSlideInterval = setInterval(() => {
        updateSlider(currentIndex + 1);
      }, 5000); // 5 saniyede bir geç
    };
    
    const resetAutoSlide = () => {
      clearInterval(autoSlideInterval);
      startAutoSlide();
    };
    
    // Başlat
    startAutoSlide();
    
    // Slider üzerine gelince otomatik geçişi durdur
    slider.addEventListener('mouseenter', () => {
      clearInterval(autoSlideInterval);
    });
    
    slider.addEventListener('mouseleave', () => {
      startAutoSlide();
    });
  });
</script>