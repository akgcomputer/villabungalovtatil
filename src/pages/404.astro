---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Sayfa Bulunamadı | Villa Bungalov Tatil">
  <div class="min-h-[70vh] flex items-center justify-center px-4 py-16">
    <div class="max-w-3xl mx-auto text-center">
      <!-- 404 Görseli / İkonu - Tatil temasına uygun -->
      <div class="mb-8 flex justify-center">
        <div class="relative">
          <div class="w-40 h-40 bg-orange-100 rounded-full flex items-center justify-center animate-pulse">
            <span class="text-6xl font-bold text-orange-600">404</span>
          </div>
          <div class="absolute -top-2 -right-2 w-12 h-12 bg-teal-500 rounded-full flex items-center justify-center text-white text-2xl animate-bounce">
            🏖️
          </div>
        </div>
      </div>

      <!-- Ana Mesaj - Tatil konseptine uygun -->
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
        Tatil rotanızda bir sapma var!
      </h1>
      <p class="text-xl text-gray-600 mb-8">
        Aradığınız sayfa sanki kaybolmuş gibi görünüyor. Tıpkı plajda kaybolan terlikler gibi...
        <br>Ama merak etmeyin, size yeni bir tatil rotası bulabiliriz.
      </p>

      <!-- Yönlendirme Seçenekleri - Tatil konseptli -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 max-w-4xl mx-auto mb-10">
        <a href="/" class="group bg-white p-6 rounded-2xl shadow-md hover:shadow-xl transition-all border border-gray-100">
          <div class="text-4xl mb-3">🏠</div>
          <h3 class="font-bold text-lg text-gray-900 group-hover:text-orange-600">Ana Sayfa</h3>
          <p class="text-gray-500 text-sm mt-1">Tatil maceranız burada başlar</p>
        </a>
        <a href="/villa-bul" class="group bg-white p-6 rounded-2xl shadow-md hover:shadow-xl transition-all border border-gray-100">
          <div class="text-4xl mb-3">🔍</div>
          <h3 class="font-bold text-lg text-gray-900 group-hover:text-orange-600">Villa Bul</h3>
          <p class="text-gray-500 text-sm mt-1">Size en uygun villayı keşfedin</p>
        </a>
        <a href="/sehir" class="group bg-white p-6 rounded-2xl shadow-md hover:shadow-xl transition-all border border-gray-100">
          <div class="text-4xl mb-3">📍</div>
          <h3 class="font-bold text-lg text-gray-900 group-hover:text-orange-600">Şehirler</h3>
          <p class="text-gray-500 text-sm mt-1">Popüler tatil bölgeleri</p>
        </a>
        <a href="/konaklama" class="group bg-white p-6 rounded-2xl shadow-md hover:shadow-xl transition-all border border-gray-100">
          <div class="text-4xl mb-3">🏡</div>
          <h3 class="font-bold text-lg text-gray-900 group-hover:text-orange-600">Konaklama Tipleri</h3>
          <p class="text-gray-500 text-sm mt-1">Villa, bungalov, daire ve daha fazlası</p>
        </a>
      </div>

      <!-- Popüler Destinasyonlar - Hızlı erişim için -->
      <div class="mb-10">
        <h3 class="text-lg font-semibold text-gray-700 mb-4">Popüler tatil rotaları:</h3>
        <div class="flex flex-wrap justify-center gap-3">
          <a href="/sehir/istanbul" class="px-4 py-2 bg-blue-100 text-blue-700 rounded-full hover:bg-blue-200 transition text-sm font-medium">
            İstanbul
          </a>
          <a href="/sehir/bursa" class="px-4 py-2 bg-green-100 text-green-700 rounded-full hover:bg-green-200 transition text-sm font-medium">
            Bursa
          </a>
          <a href="/sehir/balikesir" class="px-4 py-2 bg-yellow-100 text-yellow-700 rounded-full hover:bg-yellow-200 transition text-sm font-medium">
            Balıkesir
          </a>
          <a href="/sehir/sakarya" class="px-4 py-2 bg-purple-100 text-purple-700 rounded-full hover:bg-purple-200 transition text-sm font-medium">
            Sakarya
          </a>
          <a href="/sehir/yalova" class="px-4 py-2 bg-red-100 text-red-700 rounded-full hover:bg-red-200 transition text-sm font-medium">
            Yalova
          </a>
          <a href="/sehir/canakkale" class="px-4 py-2 bg-indigo-100 text-indigo-700 rounded-full hover:bg-indigo-200 transition text-sm font-medium">
            Çanakkale
          </a>
        </div>
      </div>
     
      <!-- Villa Sahipleri İçin Fırsat Bölümü -->
      <section class="bg-gradient-to-br from-indigo-900 via-purple-900 to-orange-900 text-white py-12 my-8 rounded-3xl">
        <div class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row items-center justify-between gap-8">
          <div class="md:w-1/2">
            <h2 class="text-3xl md:text-4xl font-bold mb-4">
              Kiraya vermek istediğiniz konutunuz mu var? <span class="text-orange-400"><br>Cevabınız Evet ise</span> 
            </h2>
            <p class="text-gray-200 text-lg mb-6">
              Konutunuzu aradığınız tatilciyle buluşturun, kkonutunuz boş kalmasın. 
              Hemen ilan verin, rezervasyon almaya başlayın!
            </p>
            <div class="flex flex-wrap gap-4">
              <a href="/villa-ekle" class="bg-orange-500 hover:bg-orange-600 text-white font-bold py-3 px-8 rounded-full transition shadow-lg hover:shadow-xl">
                Hemen Villa Ekle
              </a>
              <a href="/" class="bg-transparent border border-white hover:bg-white hover:text-indigo-900 text-white font-bold py-3 px-8 rounded-full transition">
                Ana Sayfaya Dön
              </a>
            </div>
            <p class="text-sm text-gray-300 mt-4 flex items-center gap-2">
              <span class="bg-green-500 text-white text-xs px-2 py-1 rounded-full">YENİ</span>
              İlk kiralamada komisyon yok!
            </p>
          </div>
          <div class="md:w-1/3 flex justify-center">
            <div class="bg-orange-500/20 p-6 rounded-full relative">
              <!-- Villa ikonu -->
              <svg class="w-32 h-32 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
              </svg>
              <!-- Animasyonlu yıldızlar -->
              <div class="absolute -top-2 -right-2 w-8 h-8 bg-yellow-400 rounded-full flex items-center justify-center text-indigo-900 font-bold animate-ping">
                ✨
              </div>
            </div>
          </div>
        </div>
      </section>
      
      <!-- İletişim butonu -->
      <div class="mt-8">
        <p class="text-gray-500 mb-4">Yardıma mı ihtiyacınız var?</p>
        <a href="/iletisim" class="inline-flex items-center gap-2 text-orange-600 hover:text-orange-700 font-medium">
          <span>Bize ulaşın</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</Layout>

<style>
  /* Ekstra animasyonlar */
  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
  }
  
  .animate-float {
    animation: float 3s ease-in-out infinite;
  }
</style>