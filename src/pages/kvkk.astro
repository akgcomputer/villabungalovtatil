---
// src/pages/kvkk.astro
import Layout from '../layouts/Layout.astro';
import PageTemplate from '../components/PageTemplate.astro';
---

<Layout title="KVKK Aydınlatma Metni - Villa Bungalov Tatil">
  <PageTemplate 
    title="KVKK Aydınlatma Metni" 
    subtitle="6698 sayılı Kişisel Verilerin Korunması Kanunu kapsamında aydınlatma"
    lastUpdated="Mart 2026"
  >
    <div class="space-y-6 text-gray-600">
      <section>
        <h2 class="text-lg font-semibold text-gray-800 mb-3">Veri Sorumlusu</h2>
        <p class="leading-relaxed">
          Villa Bungalov Tatil olarak, 6698 sayılı Kişisel Verilerin Korunması Kanunu ("KVKK") 
          kapsamında veri sorumlusu sıfatıyla hareket etmekteyiz.
        </p>
      </section>

      <section>
        <h2 class="text-lg font-semibold text-gray-800 mb-3">Hangi Kişisel Veriler İşlenmektedir?</h2>
        <ul class="space-y-2 list-disc pl-5">
          <li><span class="font-medium">Kimlik Bilgileri:</span> Ad, soyad</li>
          <li><span class="font-medium">İletişim Bilgileri:</span> Telefon, e-posta</li>
          <li><span class="font-medium">İşlem Bilgileri:</span> Rezervasyon, ödeme</li>
          <li><span class="font-medium">Site Kullanım Bilgileri:</span> IP, çerezler</li>
        </ul>
      </section>

      <section>
        <h2 class="text-lg font-semibold text-gray-800 mb-3">Kişisel Verilerin İşlenme Amaçları</h2>
        <ul class="space-y-2 list-disc pl-5">
          <li>Rezervasyon işlemlerinin gerçekleştirilmesi</li>
          <li>Üyelik işlemlerinin yürütülmesi</li>
          <li>Müşteri hizmetleri süreçlerinin yürütülmesi</li>
          <li>Site güvenliğinin sağlanması</li>
          <li>Yasal yükümlülüklerin yerine getirilmesi</li>
        </ul>
      </section>

      <section>
        <h2 class="text-lg font-semibold text-gray-800 mb-3">Kişisel Verilerin Aktarılması</h2>
        <p class="leading-relaxed">
          Kişisel verileriniz, rezervasyon sürecinde villa sahipleri ile paylaşılabilir. 
          Ayrıca yasal zorunluluklar halinde resmi kurumlarla paylaşılabilir.
        </p>
      </section>

      <section>
        <h2 class="text-lg font-semibold text-gray-800 mb-3">Kişisel Veri Toplamanın Yöntemi</h2>
        <p class="leading-relaxed">
          Verileriniz, site üzerinden doldurduğunuz formlar, çerezler ve WhatsApp görüşmeleri 
          aracılığıyla toplanmaktadır.
        </p>
      </section>

      <section>
        <h2 class="text-lg font-semibold text-gray-800 mb-3">KVKK Kapsamındaki Haklarınız</h2>
        <p class="leading-relaxed mb-2">KVKK'nın 11. maddesi uyarınca aşağıdaki haklara sahipsiniz:</p>
        <ul class="space-y-2 list-disc pl-5">
          <li>Veri işlenip işlenmediğini öğrenme</li>
          <li>İşlenmişse bilgi talep etme</li>
          <li>İşlenme amacını öğrenme</li>
          <li>Yurt içinde/yurt dışında aktarıldığı 3. kişileri bilme</li>
          <li>Eksik/yanlış işlenmişse düzeltilmesini isteme</li>
          <li>KVKK'nın 7. maddesinde öngörülen şartlar çerçevesinde silinmesini/yok edilmesini isteme</li>
          <li>İtiraz etme</li>
          <li>Kanuna aykırı veri işleme nedeniyle zarara uğranması halinde zararın giderilmesini talep etme</li>
        </ul>
      </section>

      <section>
        <h2 class="text-lg font-semibold text-gray-800 mb-3">İletişim</h2>
        <p class="leading-relaxed">
          Haklarınızı kullanmak için info@villabungalovtatil.com.tr adresine e-posta gönderebilir 
          veya WhatsApp hattımızdan bize ulaşabilirsiniz.
        </p>
      </section>

      <div class="bg-gray-50 rounded-lg p-4 mt-6">
        <p class="text-sm text-gray-500">
          Bu metin 6698 sayılı KVKK kapsamında hazırlanmıştır. Son güncelleme: 1 Mart 2026
        </p>
      </div>
    </div>
  </PageTemplate>
</Layout>