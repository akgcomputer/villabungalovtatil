---
// src/pages/sehir/index.astro
import Layout from '../../layouts/Layout.astro';
import { villalar } from '../../data/villalar';

// Tüm benzersiz şehirleri villa.js'den çıkar
const tumSehirler = [...new Set(villalar.map(v => v.konum?.sehir).filter(Boolean))].sort();

// Şehir adını slug'a çeviren fonksiyon
function sehirToSlug(sehirAdi) {
  if (!sehirAdi) return '';
  return sehirAdi.toLowerCase()
    .replace(/ı/g, 'i')
    .replace(/ğ/g, 'g')
    .replace(/ü/g, 'u')
    .replace(/ş/g, 's')
    .replace(/ö/g, 'o')
    .replace(/ç/g, 'c')
    .replace(/ /g, '-')
    .replace(/\./g, '');
}

// Her şehir için villa sayısını hesapla
const sehirVillaSayisi = {};
tumSehirler.forEach(sehir => {
  sehirVillaSayisi[sehir] = villalar.filter(v => v.konum?.sehir === sehir).length;
});

// Renk paleti - farklı şehirler için farklı renkler
const renkPaleti = [
  { bg: 'bg-red-100', text: 'text-red-800', hover: 'hover:bg-red-200', border: 'border-red-200' },
  { bg: 'bg-blue-100', text: 'text-blue-800', hover: 'hover:bg-blue-200', border: 'border-blue-200' },
  { bg: 'bg-green-100', text: 'text-green-800', hover: 'hover:bg-green-200', border: 'border-green-200' },
  { bg: 'bg-yellow-100', text: 'text-yellow-800', hover: 'hover:bg-yellow-200', border: 'border-yellow-200' },
  { bg: 'bg-purple-100', text: 'text-purple-800', hover: 'hover:bg-purple-200', border: 'border-purple-200' },
  { bg: 'bg-pink-100', text: 'text-pink-800', hover: 'hover:bg-pink-200', border: 'border-pink-200' },
  { bg: 'bg-indigo-100', text: 'text-indigo-800', hover: 'hover:bg-indigo-200', border: 'border-indigo-200' },
  { bg: 'bg-orange-100', text: 'text-orange-800', hover: 'hover:bg-orange-200', border: 'border-orange-200' },
  { bg: 'bg-teal-100', text: 'text-teal-800', hover: 'hover:bg-teal-200', border: 'border-teal-200' },
  { bg: 'bg-cyan-100', text: 'text-cyan-800', hover: 'hover:bg-cyan-200', border: 'border-cyan-200' },
  { bg: 'bg-emerald-100', text: 'text-emerald-800', hover: 'hover:bg-emerald-200', border: 'border-emerald-200' },
  { bg: 'bg-rose-100', text: 'text-rose-800', hover: 'hover:bg-rose-200', border: 'border-rose-200' },
  { bg: 'bg-amber-100', text: 'text-amber-800', hover: 'hover:bg-amber-200', border: 'border-amber-200' },
  { bg: 'bg-lime-100', text: 'text-lime-800', hover: 'hover:bg-lime-200', border: 'border-lime-200' },
  { bg: 'bg-fuchsia-100', text: 'text-fuchsia-800', hover: 'hover:bg-fuchsia-200', border: 'border-fuchsia-200' },
];
---

<Layout title="Tüm Şehirler - Villa Bungalov Tatil">
  <div class="max-w-7xl mx-auto px-4 py-12">
    <!-- Başlık -->
    <div class="text-center mb-12">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        Tatil Şehirleri
      </h1>
      <p class="text-gray-600 max-w-2xl mx-auto">
        Size en uygun tatil bölgesini seçin, doğayla iç içe villalar ve bungalovlar sizi bekliyor.
      </p>
    </div>

    <!-- Şehir Baloncukları Grid -->
    <div class="flex flex-wrap justify-center gap-4 md:gap-5">
      {tumSehirler.map((sehir, index) => {
        const renk = renkPaleti[index % renkPaleti.length];
        const slug = sehirToSlug(sehir);
        const villaSayisi = sehirVillaSayisi[sehir];
        
        return (
          <a
            href={`/sehir/${slug}`}
            class={`
              group relative
              ${renk.bg} ${renk.hover} ${renk.border}
              border-2 rounded-full
              px-6 py-3 md:px-8 md:py-4
              transition-all duration-300
              hover:scale-105 hover:shadow-lg
              cursor-pointer
              flex items-center gap-3
            `}
          >
            {/* Şehir adı */}
            <span class={`text-base md:text-lg font-semibold ${renk.text}`}>
              {sehir}
            </span>
            
            {/* Villa sayısı rozeti */}
            <span class={`
              inline-flex items-center justify-center
              w-7 h-7 md:w-8 md:h-8
              ${renk.text} bg-white/60 backdrop-blur-sm
              rounded-full text-xs md:text-sm font-bold
              border-2 ${renk.border}
            `}>
              {villaSayisi}
            </span>
            
            {/* Hover efekti için ok */}
            <span class={`
              absolute -right-1 -top-1
              w-5 h-5 md:w-6 md:h-6
              bg-orange-500 text-white
              rounded-full opacity-0 group-hover:opacity-100
              transition-opacity duration-300
              flex items-center justify-center
              text-xs md:text-sm
            `}>
              →
            </span>
          </a>
        );
      })}
    </div>

    <!-- Alt açıklama -->
    <div class="text-center mt-16 text-gray-500 text-sm">
      <p>{tumSehirler.length} farklı şehirde toplam {villalar.length} villa seçeneği</p>
    </div>
  </div>
</Layout>

<style>
  /* İsterseniz özel animasyonlar ekleyebilirsiniz */
  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-5px); }
  }
  
  .group:hover {
    animation: float 2s ease-in-out infinite;
  }
</style>