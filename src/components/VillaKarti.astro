---
// src/components/VillaKarti.astro
export interface Props {
  villa: any;
  renderStars: (rating: number) => string;
}

const { villa, renderStars } = Astro.props;
const puan = villa.puan?.ortalama || 0;
const yildizlar = renderStars(puan);
const degerlendirmeSayisi = villa.puan?.degerlendirmeSayisi || 0;
---

<a href={`/villa/${villa.slug}`} class="group bg-white rounded-xl shadow-lg border border-gray-200 overflow-hidden hover:shadow-2xl transition-all hover:-translate-y-1 block">
  <div class="relative h-48 overflow-hidden">
    <img 
      src={villa.resimler[0]} 
      alt={villa.baslik} 
      class="w-full h-full object-cover group-hover:scale-105 transition duration-300"
      loading="lazy"
    />
    {villa.oneCikanSunduklar?.ozelJakuzi && (
      <span class="absolute top-2 right-2 bg-purple-600 text-white text-xs px-2 py-1 rounded-full">
        🛁 Jakuzili
      </span>
    )}
    {villa.oneCikanSunduklar?.klima && (
      <span class="absolute top-2 left-2 bg-blue-600 text-white text-xs px-2 py-1 rounded-full">
        ❄️ Klima
      </span>
    )}
  </div>
  
  <div class="p-4">
    <div class="flex items-start justify-between mb-1">
      <h3 class="font-semibold text-gray-800 group-hover:text-orange-600 text-lg line-clamp-1">
        {villa.baslik}
      </h3>
    </div>
    
    <p class="text-sm text-gray-500 mb-2">
      {villa.konum.ilce} / {villa.konum.sehir}
    </p>
    
    <div class="flex items-center gap-2 text-sm text-gray-600 mb-3">
      <span class="flex items-center gap-1">👥 {villa.ozetBilgiler.misafir}</span>
      <span>•</span>
      <span class="flex items-center gap-1">🛏️ {villa.ozetBilgiler.yatakOdasi}</span>
      <span>•</span>
      <span class="flex items-center gap-1">🚿 {villa.ozetBilgiler.banyo}</span>
    </div>
    
    <div class="flex items-center justify-between">
      <div class="flex items-center">
        <span class="text-yellow-400 text-lg tracking-wider">{yildizlar}</span>
        <span class="ml-1 font-medium text-gray-800">
          {puan > 0 ? puan.toFixed(1) : 'Yeni'}
        </span>
        {degerlendirmeSayisi > 0 && (
          <span class="text-gray-400 text-sm ml-1">({degerlendirmeSayisi})</span>
        )}
      </div>
      
      <div class="text-right">
        <span class="text-orange-600 font-bold">
          {villa.fiyat.paraBirimi} {villa.fiyat.gecelik.toLocaleString('tr-TR')}
        </span>
        <span class="text-xs text-gray-500 block">/gece</span>
      </div>
    </div>
  </div>
</a>