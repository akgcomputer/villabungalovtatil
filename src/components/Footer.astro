---
// src/components/Footer.astro

// Mevcut yılı al
const currentYear = new Date().getFullYear();

// Popüler şehirler
const sehirler = [
  { name: 'İstanbul', href: '/sehir/i̇stanbul' },
  { name: 'Bursa', href: '/sehir/bursa' },
  { name: 'Balıkesir', href: '/sehir/balikesir' },
  { name: 'Yalova', href: '/sehir/yalova' },
  { name: 'Sakarya', href: '/sehir/sakarya' },
  { name: 'Kocaeli', href: '/sehir/kocaeli' },
  { name: 'Tekirdağ', href: '/sehir/tekirdag' },
  { name: 'Çanakkale', href: '/sehir/canakkale' },
  { name: 'Kırklareli', href: '/sehir/kirklareli' },
  { name: 'Edirne', href: '/sehir/edirne' },
  { name: 'Antalya', href: '/sehir/antalya' },
  { name: 'Muğla', href: '/sehir/mugla' }
];

// Konaklama tipleri
const konaklamaTipleri = [
  { name: 'Tüm Konaklamalar', href: '/konaklama' },
  { name: 'Villalar', href: '/konaklama/villa' },
  { name: 'Bungalovlar', href: '/konaklama/bungalov' },
  { name: 'Müstakil Evler', href: '/konaklama/ev' },
  { name: 'Yazlıklar', href: '/konaklama/yazlik' },
  { name: 'Daireler', href: '/konaklama/daire' },
  { name: 'Dağ Evleri', href: '/konaklama/dag-evi' },
  { name: 'Çiftlik Evleri', href: '/konaklama/kir-evi' },
  { name: 'Kiralık Tekne', href: '/konaklama/tekne' }
];

// Tur kategorileri
const turKategorileri = [
  { name: 'Balkan Turları', href: '/tur/balkan' },
  { name: 'Avrupa Turları', href: '/tur/avrupa' },
  { name: 'Umre Turları', href: '/tur/umre' },
  { name: 'Uzak Doğu Turları', href: '/tur/uzakdogu' },
  { name: 'Afrika Turları', href: '/tur/afrika' },
  { name: 'Körfez Turları', href: '/tur/korfez' },
  { name: 'Gemi Turları', href: '/tur/gemi' },
  { name: 'Kültür Turları', href: '/tur/kultur' }
];

// Popüler tatil bölgeleri
const tatilBolgeleri = [
  { name: 'Marmara Bölgesi', href: '/bolge/marmara' },
  { name: 'Ege Bölgesi', href: '/bolge/ege' },
  { name: 'Akdeniz Bölgesi', href: '/bolge/akdeniz' },
  { name: 'Karadeniz Bölgesi', href: '/bolge/karadeniz' },
  { name: 'İç Anadolu', href: '/bolge/ic-anadolu' },
  { name: 'Doğu Anadolu', href: '/bolge/dogu-anadolu' },
  { name: 'Güneydoğu', href: '/bolge/guneydogu' }
];

// Kurumsal linkler
const kurumsalLinkler = [
  { name: 'Hakkımızda', href: '/hakkimizda' },
  { name: 'İletişim', href: '/iletisim' },
  { name: 'Sıkça Sorulan Sorular', href: '/sss' },
  { name: 'Kullanım Şartları', href: '/kullanim-sartlari' },
  { name: 'Gizlilik Politikası', href: '/gizlilik-politikasi' },
  { name: 'KVKK Aydınlatma Metni', href: '/kvkk' },
  { name: 'Çerez Politikası', href: '/cerez-politikasi' }
];

// Villa sahipleri için
const villaSahipleri = [
  { name: 'Evini/Konutunu Ekle', href: '/villa-ekle', highlight: true },
  { name: 'Nasıl Çalışır?', href: '/villa-sahibi-rehberi' },
  { name: 'Komisyon Oranları', href: '/komisyon-oranlari' },
  { name: 'Reklam Ver', href: '/reklam-ver' }
];

// İletişim Bilgileri
const iletisim = {
  telefon: '+90 (541) 246 54 29',
  whatsapp: '+90 (541) 246 54 29',
  email: 'info @ villabungalovtatil.com.tr',
  adres: 'İstanbul, Türkiye'
};

// Sosyal medya
const sosyalMedya = [
  { name: 'Instagram', icon: '📷', href: 'https://instagram.com/villabungalovtatil' },
  { name: 'Facebook', icon: '📘', href: 'https://facebook.com/villabungalovtatil' },
  { name: 'Twitter', icon: '🐦', href: 'https://twitter.com/villabungalov' },
  { name: 'TikTok', icon: '🎵', href: 'https://tiktok.com/@villabungalovtatil' }
];
---

<footer class="bg-gradient-to-b from-gray-900 to-gray-950 text-gray-400 border-t border-gray-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    
    <!-- Ana Mesaj - Villa Tatil -->
    <div class="text-center mb-12 pb-8 border-b border-gray-800">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-3">Hayalinizdeki Tatil Burada Başlıyor</h2>
      <p class="text-gray-400 max-w-3xl mx-auto text-sm md:text-base leading-relaxed">
        Türkiye'nin en güzel bölgelerinde, doğayla iç içe villalar ve bungalovlar. 
        Şehrin stresinden uzaklaşmak, huzurlu bir tatil geçirmek için size en uygun konaklama seçeneğini bulun. 
        <span class="text-orange-400 font-medium">Konut sahipleri</span> de meskenlerini ekleyerek binlerce tatilciye ulaşabilir.
      </p>
    </div>

    <!-- Ana Kategoriler Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12 mb-12">
      
      <!-- Sütun 1: Popüler Şehirler -->
      <div>
        <h3 class="text-white text-lg font-semibold mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          POPÜLER TATİL ŞEHİRLERİ
        </h3>
        <div class="grid grid-cols-2 gap-x-4 gap-y-2 text-sm">
          {sehirler.map((sehir) => (
            <a 
              href={sehir.href} 
              class="hover:text-orange-400 transition-colors duration-200 flex items-center gap-1"
            >
              <span class="text-gray-600">▹</span>
              {sehir.name}
            </a>
          ))}
        </div>

        <h3 class="text-white text-lg font-semibold mt-6 mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z" />
          </svg>
          TATİL BÖLGELERİ
        </h3>
        <div class="space-y-2 text-sm">
          {tatilBolgeleri.map((bolge) => (
            <a 
              href={bolge.href} 
              class="hover:text-orange-400 transition-colors duration-200 flex items-center gap-2"
            >
              <span class="text-gray-600">▹</span>
              {bolge.name}
            </a>
          ))}
        </div>
      </div>

      <!-- Sütun 2: Konaklama Tipleri & Turlar -->
      <div>
        <h3 class="text-white text-lg font-semibold mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
          </svg>
          KONAKLAMA TİPLERİ
        </h3>
        <ul class="space-y-2 text-sm mb-8">
          {konaklamaTipleri.map((item) => (
            <li>
              <a href={item.href} class="hover:text-orange-400 transition-colors duration-200 flex items-center gap-2">
                <span class="text-gray-600">▹</span>
                {item.name}
              </a>
            </li>
          ))}
        </ul>

        <h3 class="text-white text-lg font-semibold mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          TUR KATEGORİLERİ
        </h3>
        <ul class="space-y-2 text-sm">
          {turKategorileri.map((item) => (
            <li>
              <a href={item.href} class="hover:text-orange-400 transition-colors duration-200 flex items-center gap-2">
                <span class="text-gray-600">▹</span>
                {item.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Sütun 3: Villa Sahipleri & Kurumsal -->
      <div>
        <h3 class="text-white text-lg font-semibold mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          VİLLA SAHİPLERİ İÇİN
        </h3>
        <ul class="space-y-2 text-sm mb-8">
          {villaSahipleri.map((item) => (
            <li>
              <a 
                href={item.href} 
                class={item.highlight 
                  ? 'flex items-center gap-2 text-orange-400 hover:text-orange-300 font-medium transition-colors duration-200' 
                  : 'hover:text-orange-400 transition-colors duration-200 flex items-center gap-2'
                }
              >
                <span class="text-gray-600">{item.highlight ? '✨' : '▹'}</span>
                {item.name}
              </a>
            </li>
          ))}
        </ul>

        <h3 class="text-white text-lg font-semibold mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
          </svg>
          KURUMSAL
        </h3>
        <ul class="space-y-2 text-sm">
          {kurumsalLinkler.map((item) => (
            <li>
              <a href={item.href} class="hover:text-orange-400 transition-colors duration-200 flex items-center gap-2">
                <span class="text-gray-600">▹</span>
                {item.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Sütun 4: İletişim & Bizi Takip Edin -->
      <div>
        <h3 class="text-white text-lg font-semibold mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          İLETİŞİM
        </h3>
        
        <div class="space-y-3 text-sm mb-6">
          <div class="flex items-center gap-3">
            <span class="text-orange-400">📞</span>
            <a href={`tel:${iletisim.telefon}`} class="hover:text-orange-400 transition-colors">
              {iletisim.telefon}
            </a>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-orange-400">📱</span>
            <a href={`https://wa.me/${iletisim.whatsapp.replace(/\D/g, '')}`} target="_blank" class="hover:text-orange-400 transition-colors">
              WhatsApp
            </a>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-orange-400">✉️</span>
            <a href={`mailto:${iletisim.email}`} class="hover:text-orange-400 transition-colors">
              {iletisim.email}
            </a>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-orange-400">📍</span>
            <span>{iletisim.adres}</span>
          </div>
        </div>

        <h3 class="text-white text-lg font-semibold mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
          </svg>
          BİZİ TAKİP EDİN
        </h3>
        
        <div class="flex flex-wrap gap-3 mb-6">
          {sosyalMedya.map((sosyal) => (
            <a 
              href={sosyal.href}
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 bg-gray-800 hover:bg-orange-600 rounded-full flex items-center justify-center text-xl transition-colors duration-200"
              aria-label={sosyal.name}
            >
              {sosyal.icon}
            </a>
          ))}
        </div>

        <!-- E-bülten -->
        <div class="bg-gray-800/50 rounded-lg p-4">
          <h4 class="text-white text-sm font-semibold mb-2">Fırsatlardan Haberdar Olun</h4>
          <p class="text-xs text-gray-400 mb-3">Yeni villalar ve kampanyalar için e-bültenimize kaydolun.</p>
          <form class="flex gap-2">
            <input 
              type="email" 
              placeholder="E-posta adresiniz" 
              class="flex-1 px-3 py-2 bg-gray-700 border border-gray-600 rounded-lg text-xs text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-orange-500"
            />
            <button class="px-3 py-2 bg-orange-600 hover:bg-orange-700 text-white text-xs font-medium rounded-lg transition-colors">
              Gönder
            </button>
          </form>
        </div>
      </div>
    </div>

    <!-- Alt Banner - Öne Çıkanlar -->
    <div class="border-t border-gray-800 pt-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-center text-sm">
        <div class="flex flex-col items-center justify-center gap-2 text-gray-500">
          <span class="text-3xl">🏡</span>
          <span class="font-medium text-white">500+ Villa</span>
          <span class="text-xs">Türkiye'nin dört bir yanında</span>
        </div>
        <div class="flex flex-col items-center justify-center gap-2 text-gray-500">
          <span class="text-3xl">⭐</span>
          <span class="font-medium text-white">4.8 Ortalama Puan</span>
          <span class="text-xs">Misafir memnuniyeti</span>
        </div>
        <div class="flex flex-col items-center justify-center gap-2 text-gray-500">
          <span class="text-3xl">🔒</span>
          <span class="font-medium text-white">Güvenli Rezervasyon</span>
          <span class="text-xs">Kaparo koruması</span>
        </div>
        <div class="flex flex-col items-center justify-center gap-2 text-gray-500">
          <span class="text-3xl">💬</span>
          <span class="font-medium text-white">7/24 Destek</span>
          <span class="text-xs">WhatsApp ile anında yardım</span>
        </div>
      </div>
    </div>

    <!-- Telif Hakkı -->
    <div class="border-t border-gray-800 mt-8 pt-6 text-center text-sm text-gray-500">
      <p>&copy; {currentYear} Villa Bungalov Tatil. Tüm hakları saklıdır.</p>
      <p class="mt-2 text-xs text-gray-600">
        En güzel tatil evleri, villalar ve bungalovlar sizi bekliyor.
      </p>
    </div>
  </div>
</footer>